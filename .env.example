# Google Maps API key
# Get one: https://developers.google.com/maps/gmp-get-started
# Enable these APIs in the Google Cloud Console:
#   - Maps JavaScript API (map display; also serves Geocoder + ElevationService)
#   - Geocoding API      (location search)
#   - Elevation API      (real terrain relief)
# Without a key the map shows a notice and terrain falls back to procedural.
#
# Streets & buildings overlays still use the keyless OSM Overpass API.
VITE_GOOGLE_MAPS_API_KEY=VITE_GOOGLE_MAPS_API_KEY

# Mapbox access token (public "pk.*" token)
# Get one: https://console.mapbox.com/ → Tokens
# Used by the /skylines city map (Mapbox GL JS, Streets v8 vector tiles).
# Without it the skylines map shows a notice; the relief itself still works
# (it is built from OSM Overpass data, not Mapbox tiles).
VITE_MAPBOX_TOKEN=VITE_MAPBOX_TOKEN

# Backend API base URL (order + phone/OTP verification).
# e.g. https://api.cairn.studio  — leave empty to hit same-origin "/…" paths.
# Endpoints used: POST /otp/request, POST /otp/verify, POST /orders (multipart).
VITE_API_BASE=
