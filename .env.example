# Google Maps API Key
# Get your API key: https://developers.google.com/maps/gmp-get-started
# Required APIs (enable in Google Cloud Console):
#   - Maps JavaScript API (for map display)
#   - Geocoding API (for location search)
#   - Elevation API (for terrain elevation data)
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

# Mapbox access token (for the 3D Skyline: buildings, streets, water, parks)
# Get a token: https://account.mapbox.com/access-tokens/
# Uses the Vector Tiles API (mapbox.mapbox-streets-v8) — a default public token works.
VITE_MAPBOX_TOKEN=pk.your-mapbox-public-token-here
