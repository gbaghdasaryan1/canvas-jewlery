# No key is needed for the core app:
#   - Map display        → OpenStreetMap tiles via Leaflet
#   - Location search     → Nominatim (OpenStreetMap)
#   - Terrain elevation   → Open-Meteo (Copernicus DEM)

# Mapbox access token — OPTIONAL, only for the 3D Skyline (buildings, streets, water, parks)
# Get a token: https://account.mapbox.com/access-tokens/
# Uses the Vector Tiles API (mapbox.mapbox-streets-v8) — a default public token works.
VITE_MAPBOX_TOKEN=pk.your-mapbox-public-token-here
